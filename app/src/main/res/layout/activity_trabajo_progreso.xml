<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <!-- CABECERA VERDE -->
    <View
        android:id="@+id/bgCabeceraProgreso"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#059669"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Botón de Volver -->
    <FrameLayout
        android:id="@+id/btnVolverProgreso"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_icono_cristal"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_flecha_volver" />
    </FrameLayout>

    <!-- Etiqueta En Progreso -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_icono_cristal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="En Progreso"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnVolverProgreso"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnVolverProgreso" />

    <TextView
        android:id="@+id/lblClienteProgreso"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:text="Restaurante El Buen Sabor"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/btnVolverProgreso"
        app:layout_constraintTop_toBottomOf="@+id/btnVolverProgreso" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@+id/bgCabeceraProgreso"
        app:layout_constraintBottom_toTopOf="@+id/contenedorBotonFinalizar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- TARJETA 1: MATERIALES -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Materiales Usados"
                            android:textColor="#0F172A"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_package_blue"
                            android:drawablePadding="12dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:id="@+id/txtContadorMateriales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_input_gray"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="0"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/contenedorListaMateriales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- BUSCADOR DE MATERIALES -->
                    <AutoCompleteTextView
                        android:id="@+id/txtNombreMaterial"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_gray"
                        android:hint="Escribe para buscar material..."
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"
                        android:completionThreshold="1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <EditText
                            android:id="@+id/txtCantidadMaterial"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_gray"
                            android:hint="Cantidad"
                            android:inputType="numberDecimal"
                            android:textColorHint="#94A3B8"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:layout_marginEnd="12dp"/>

                        <Spinner
                            android:id="@+id/spinnerUnidadMaterial"
                            android:layout_width="100dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_gray"
                            android:paddingHorizontal="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnAddMaterial"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_dashed_box"
                        android:text="+   Añadir Material"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA 2: FOTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Foto de la Avería"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:drawableStart="@drawable/ic_camera_purple"
                        android:drawablePadding="12dp"
                        android:layout_marginBottom="20dp"/>

                    <FrameLayout
                        android:id="@+id/btnTomarFoto"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:background="@drawable/bg_dashed_box"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgFotoCapturada"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="4dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/panelTextoCamara"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_camera_large" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Tomar Foto"
                                android:textColor="#475569"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA 3: FIRMA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Firma del Cliente"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:drawableStart="@drawable/ic_pen_orange"
                        android:drawablePadding="12dp"
                        android:layout_marginBottom="20dp"/>

                    <FrameLayout
                        android:id="@+id/btnRecogerFirma"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_dashed_box"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgFirmaCapturada"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="12dp"
                            android:scaleType="fitCenter"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/panelTextoFirma"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_pen_large" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Recoger Firma"
                                android:textColor="#475569"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA 4: OBSERVACIONES  -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Observaciones / Compras Extra"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/txtObservaciones"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_input_gray"
                        android:gravity="top|start"
                        android:hint="Añade aquí materiales extra comprados en ferretería o notas del aviso..."
                        android:padding="16dp"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo valoras nuestro servicio?"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <RatingBar
                        android:id="@+id/ratingBarCliente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:rating="5.0"
                        android:progressTint="#EAB308" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTÓN INFERIOR -->
    <FrameLayout
        android:id="@+id/contenedorBotonFinalizar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="60dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btnFinalizarTrabajo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_boton_gradiente"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_circle_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finalizar Trabajo"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>